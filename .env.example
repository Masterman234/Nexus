# Nexus Environment Variables
# Copy this file to .env for local development.
#
# Nested ASP.NET config keys use double-underscore (__).
# Example: Webhook__GithubSecret maps to configuration["Webhook:GithubSecret"].

# Database
DB_CONNECTION_STRING=Host=localhost;Port=5432;Database=nexus;Username=nexus;Password=password

# Redis
REDIS_CONNECTION_STRING=localhost:6379

# RabbitMQ
RABBITMQ_HOST=localhost
RABBITMQ_USER=guest
RABBITMQ_PASS=guest

# AI Integration
GEMINI_API_KEY=your_api_key_here

# GitHub webhook HMAC secret. Must match the "Secret" field on the GitHub webhook config.
# Generate locally with: [Convert]::ToBase64String((1..32 | %{ [byte](Get-Random -Max 256) }))
Webhook__GithubSecret=

# Target channel id (Guid) the github-bot should post to. Find it by SELECT'ing from
# nexus.channels. If unset, the bot falls back to the oldest channel named 'general'.
Webhook__GithubTargetChannelId=

# Observability
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=Nexus.Api