# Nexus PRODUCTION environment.
# Copy this to `.env` on the deploy host (next to docker-compose.prod.yml) and
# fill in real values. NEVER commit the real .env.
#
# Generate strong secrets on the host, e.g.:
#   openssl rand -base64 48        # for JWT_SECRET / JWT_REFRESH_PEPPER / passwords

# --- Database ---
POSTGRES_USER=nexus
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=nexus

# --- RabbitMQ (do NOT leave as guest/guest in prod) ---
RABBITMQ_USER=nexus
RABBITMQ_PASS=change-me-strong-password

# --- JWT (HS256 requires a key of at least 32 bytes) ---
JWT_SECRET=change-me-at-least-32-bytes-long-random-string
JWT_REFRESH_PEPPER=change-me-another-random-string

# --- AI (Gemini) ---
GEMINI_API_KEY=your_gemini_api_key

# --- GitHub webhook (optional; leave blank to disable webhook verification setup) ---
WEBHOOK_GITHUB_SECRET=
WEBHOOK_GITHUB_TARGET_CHANNEL_ID=

# --- Demo seeding (true populates a demo workspace/channels/tickets + guest user) ---
SEED_DEMO=true

# --- Public domain for HTTPS (free DuckDNS subdomain pointed at this VM's IP) ---
NEXUS_DOMAIN=nexus-demo.duckdns.org

# --- Observability (optional; leave blank to disable OTLP export) ---
OTEL_EXPORTER_OTLP_ENDPOINT=

# --- Images (CD overrides these with GHCR refs; defaults build/run locally) ---
# API_IMAGE=ghcr.io/<owner>/nexus-api:latest
# WEB_IMAGE=ghcr.io/<owner>/nexus-web:latest
